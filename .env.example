# Скопировать в .env
# --- OpenRouter (LLM для режиссёра и детализации сцен) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- ComfyUI ---
COMFYUI_URL=http://host.docker.internal:8188
COMFYUI_AUTOSTART=true
COMFYUI_PATH=./vendor/ComfyUI
COMFYUI_PORT=8188

# --- API доступ ---
# Если пусто, API без ключа. Если задано, передавайте X-API-Key или Bearer token.
API_KEY=
# Для браузерного UI (через запятую), пример: http://127.0.0.1:8000,http://localhost:8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- HuggingFace (опционально для приватных репо) ---
HF_TOKEN=

# --- Whisper ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# --- Пути ---
DATA_DIR=./data

# --- FFmpeg ---
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- Видео по умолчанию (Wan 2.2 native) ---
DEFAULT_GENERATOR=wan
DEFAULT_WIDTH=832
DEFAULT_HEIGHT=480
DEFAULT_FPS=16

# --- Длина сцены, секунды ---
SCENE_MIN=6.0
SCENE_MAX=12.0
SCENE_TARGET=8.0
