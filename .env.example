# Скопировать в .env

# ============================================================
# === ОБЯЗАТЕЛЬНЫЕ (SaaS-режим) ==============================
# ============================================================

# Секретный ключ для JWT и шифрования ключей пользователей.
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_secret

# Email-адреса администраторов (через запятую). Получат is_admin=true при регистрации.
ADMIN_EMAILS=admin@example.com

# WaveSpeed API ключ — admin-fallback (если пусто, admin тоже должен вводить свой в настройках)
WAVESPEED_API_KEY=
WAVESPEED_BASE_URL=https://api.wavespeed.ai/api/v3

# База данных (SQLite по умолчанию, можно заменить на Postgres)
DATABASE_URL=sqlite+aiosqlite:///./data/clipmaker.db
# Пример для Postgres: postgresql+asyncpg://user:pass@db:5432/clipmaker

# ============================================================
# === ОПЦИОНАЛЬНЫЕ ===========================================
# ============================================================

# --- OpenRouter (LLM для режиссёра и детализации сцен) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- ComfyUI (только для локальной self-hosted генерации) ---
COMFYUI_URL=http://host.docker.internal:8188
COMFYUI_AUTOSTART=false
COMFYUI_PATH=./vendor/ComfyUI
COMFYUI_PORT=8188

# --- Cookie безопасность (true в prod за HTTPS, false для localhost) ---
SECURE_COOKIE=false

# --- CORS (через запятую) ---
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# --- HuggingFace (опционально для приватных моделей) ---
HF_TOKEN=

# --- Whisper ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- Пути ---
DATA_DIR=./data

# --- FFmpeg ---
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- Видео по умолчанию ---
DEFAULT_GENERATOR=ws-wan22-ti2v-5b
DEFAULT_FPS=24

# --- Длина сцены, секунды ---
SCENE_MIN=6.0
SCENE_MAX=12.0
SCENE_TARGET=8.0
