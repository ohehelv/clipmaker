# Скопировать в .env
# --- OpenRouter (LLM для режиссёра и детализации сцен) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- ComfyUI ---
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_AUTOSTART=true
COMFYUI_PATH=./vendor/ComfyUI
COMFYUI_PORT=8188

# --- HuggingFace (опционально для приватных репо) ---
HF_TOKEN=

# --- Whisper ---
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

# --- Пути ---
DATA_DIR=./data

# --- FFmpeg ---
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- Видео по умолчанию (Wan 2.2 native) ---
DEFAULT_GENERATOR=wan
DEFAULT_WIDTH=1280
DEFAULT_HEIGHT=704
DEFAULT_FPS=24

# --- Длина сцены, секунды ---
SCENE_MIN=3.0
SCENE_MAX=8.0
SCENE_TARGET=5.0
